# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Channel IDs
FOOTBALL_CHANNEL_ID=-100...
BASKETBALL_CHANNEL_ID=-100...
TENNIS_CHANNEL_ID=-100...

# API Keys
ODDS_API_KEY=your_odds_api_key_here
# TheSportsDB API Key (if needed)
THESPORTSDB_API_KEY=3

# Database
DATABASE_URL=sqlite:///sports_bot.db
# PostgreSQL example: postgresql://user:password@localhost:5432/dbname

# Redis (Optional but recommended)
REDIS_URL=redis://localhost:6379/0

# App Settings
LOG_LEVEL=INFO
TIMEZONE=UTC
POSTING_FREQUENCY_DAILY=3
MAX_POSTS_PER_DAY=20
